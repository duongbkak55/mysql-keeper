#
# ProxySQL on the DR side. Points at pxc-dr by default (DR is the local
# cluster for this ProxySQL). After a failover promotes DR, this
# ProxySQL keeps routing to pxc-dr. Before failover, the writer HG
# entry is OFFLINE_HARD so writes never hit DR (which is read_only=ON).
#
# Exactly mirrors proxysql-dc.cnf semantics — see comments there.
#
datadir="/var/lib/proxysql"

admin_variables =
{
    admin_credentials = "admin:stagingpass;keeper:stagingpass"
    mysql_ifaces = "0.0.0.0:6032"
    refresh_interval = 2000
}

mysql_variables =
{
    threads = 2
    max_connections = 512
    default_query_timeout = 10000
    server_version = "8.0.35"
    interfaces = "0.0.0.0:6033"
    monitor_username = "monitor"
    monitor_password = "stagingpass"
    monitor_connect_interval = 60000
    monitor_ping_interval = 10000
    monitor_read_only_interval = 3000
    monitor_read_only_timeout = 2500
}

mysql_servers =
(
    # Writer HG starts OFFLINE_HARD — DR is read-only, no writes should
    # flow here until the controller flips routing.
    { hostgroup = 10, hostname = "pxc-dr", port = 3306, max_connections = 200, weight = 1000, status = "OFFLINE_HARD" },
    { hostgroup = 20, hostname = "pxc-dr", port = 3306, max_connections = 200, weight = 1000, status = "ONLINE" }
)

mysql_users =
(
    { username = "root", password = "stagingpass", default_hostgroup = 10, active = 1, transaction_persistent = 1 }
)

mysql_query_rules =
(
    { rule_id = 1, active = 1, match_pattern = "^SELECT .* FOR UPDATE", destination_hostgroup = 10, apply = 1 },
    { rule_id = 2, active = 1, match_pattern = "^SELECT", destination_hostgroup = 20, apply = 1 }
)
